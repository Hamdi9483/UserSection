<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
  <title>🔍 قارئ الكيو آر - نظام العيادات</title>
  
  <!-- خط عربي جميل -->
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet">
  
  <!-- مكتبة html5-qrcode للمسح [[2]][[4]] -->
  <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
  
  <!-- مكتبة Supabase JavaScript [[16]][[18]] -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    :root {
      --primary: #4f46e5;
      --primary-dark: #4338ca;
      --secondary: #10b981;
      --danger: #ef4444;
      --warning: #f59e0b;
      --bg-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      --card-bg: rgba(255, 255, 255, 0.95);
      --text-primary: #1f2937;
      --text-secondary: #6b7280;
      --shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.2);
      --radius: 20px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Tajawal', sans-serif;
      background: var(--bg-gradient);
      min-height: 100vh;
      color: var(--text-primary);
      direction: rtl;
      text-align: right;
      padding: 20px;
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }

    .container {
      width: 100%;
      max-width: 500px;
      margin: 20px auto;
    }

    /* رأس الصفحة */
    .header {
      background: var(--card-bg);
      border-radius: var(--radius);
      padding: 25px;
      margin-bottom: 20px;
      box-shadow: var(--shadow);
      text-align: center;
      animation: slideDown 0.5s ease;
    }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .header h1 {
      font-size: 1.8rem;
      color: var(--primary);
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .header p {
      color: var(--text-secondary);
      font-size: 0.95rem;
    }

    /* بطاقة الماسح الضوئي */
    .scanner-card {
      background: var(--card-bg);
      border-radius: var(--radius);
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: var(--shadow);
      animation: fadeIn 0.6s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    #qr-reader {
      width: 100%;
      border-radius: 16px;
      overflow: hidden;
      background: #000;
      margin-bottom: 15px;
    }

    #qr-reader video {
      border-radius: 12px;
    }

    .scanner-controls {
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      padding: 12px 24px;
      border: none;
      border-radius: 12px;
      font-family: inherit;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
    }

    .btn-primary:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(79, 70, 229, 0.4);
    }

    .btn-secondary {
      background: #e5e7eb;
      color: var(--text-primary);
    }

    .btn-secondary:hover {
      background: #d1d5db;
    }

    .btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }

    /* منطقة النتائج */
    .result-card {
      background: var(--card-bg);
      border-radius: var(--radius);
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: var(--shadow);
      display: none;
      animation: slideUp 0.4s ease;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .result-card.show {
      display: block;
    }

    .result-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding-bottom: 15px;
      border-bottom: 2px solid #f3f4f6;
      margin-bottom: 15px;
    }

    .result-icon {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
    }

    .result-icon.success {
      background: #d1fae5;
      color: var(--secondary);
    }

    .result-icon.not-found {
      background: #fef3c7;
      color: var(--warning);
    }

    .result-icon.error {
      background: #fee2e2;
      color: var(--danger);
    }

    .result-title {
      font-weight: 700;
      font-size: 1.1rem;
    }

    .qr-content {
      background: #f9fafb;
      padding: 12px 16px;
      border-radius: 10px;
      font-family: monospace;
      direction: ltr;
      text-align: left;
      margin-bottom: 15px;
      word-break: break-all;
      border-right: 4px solid var(--primary);
    }

    .appointment-details {
      display: grid;
      gap: 10px;
    }

    .detail-row {
      display: flex;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px dashed #e5e7eb;
    }

    .detail-row:last-child {
      border-bottom: none;
    }

    .detail-label {
      color: var(--text-secondary);
      font-weight: 500;
    }

    .detail-value {
      font-weight: 600;
      color: var(--text-primary);
    }

    .status-badge {
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .status-pending {
      background: #fef3c7;
      color: #92400e;
    }

    .status-confirmed {
      background: #d1fae5;
      color: #065f46;
    }

    .status-cancelled {
      background: #fee2e2;
      color: #991b1b;
    }

    /* حالة التحميل */
    .loading {
      display: none;
      text-align: center;
      padding: 30px;
      color: var(--text-secondary);
    }

    .loading.show {
      display: block;
    }

    .spinner {
      width: 40px;
      height: 40px;
      border: 4px solid #e5e7eb;
      border-top-color: var(--primary);
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin: 0 auto 15px;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* رسائل الحالة */
    .status-message {
      padding: 12px 16px;
      border-radius: 12px;
      margin-bottom: 15px;
      font-size: 0.9rem;
      display: none;
    }

    .status-message.show {
      display: block;
      animation: fadeIn 0.3s ease;
    }

    .status-message.info {
      background: #dbeafe;
      color: #1e40af;
      border-right: 4px solid #3b82f6;
    }

    .status-message.success {
      background: #d1fae5;
      color: #065f46;
      border-right: 4px solid var(--secondary);
    }

    .status-message.error {
      background: #fee2e2;
      color: #991b1b;
      border-right: 4px solid var(--danger);
    }

    /* تذييل الصفحة */
    .footer {
      text-align: center;
      color: rgba(255, 255, 255, 0.9);
      font-size: 0.9rem;
      padding: 20px;
      opacity: 0.9;
    }

    .footer a {
      color: white;
      text-decoration: none;
      font-weight: 600;
    }

    /* استجابة للشاشات الصغيرة */
    @media (max-width: 480px) {
      body {
        padding: 10px;
      }
      
      .header h1 {
        font-size: 1.5rem;
      }
      
      .btn {
        padding: 10px 18px;
        font-size: 0.9rem;
      }
    }

    /* تأثيرات تفاعلية */
    .pulse {
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(79, 70, 229, 0.4); }
      50% { box-shadow: 0 0 0 15px rgba(79, 70, 229, 0); }
    }

    /* إخفاء عناصر المكتبة غير المرغوبة */
    #qr-reader > div:first-child {
      border-radius: 12px !important;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- رأس الصفحة -->
    <header class="header">
      <h1>🔍 قارئ الكيو آر</h1>
      <p>امسح الكود للبحث عن المواعيد في قاعدة البيانات</p>
    </header>

    <!-- بطاقة الماسح -->
    <div class="scanner-card">
      <div id="qr-reader"></div>
      
      <div class="scanner-controls">
        <button id="startScan" class="btn btn-primary pulse">
          🎥 بدء المسح
        </button>
        <button id="stopScan" class="btn btn-secondary" disabled>
          ⏹ إيقاف
        </button>
        <button id="flipCamera" class="btn btn-secondary">
          🔄 تبديل الكاميرا
        </button>
      </div>

      <div id="statusMessage" class="status-message"></div>
    </div>

    <!-- حالة التحميل -->
    <div id="loading" class="loading">
      <div class="spinner"></div>
      <p>جاري البحث في قاعدة البيانات...</p>
    </div>

    <!-- بطاقة النتيجة -->
    <div id="resultCard" class="result-card">
      <div class="result-header">
        <div id="resultIcon" class="result-icon success">✓</div>
        <div class="result-title" id="resultTitle">تم العثور على البيانات!</div>
      </div>
      
      <div class="qr-content" id="qrContent"></div>
      
      <div id="appointmentDetails" class="appointment-details">
        <!-- سيتم ملؤها ديناميكيًا -->
      </div>
    </div>

    <!-- تذييل الصفحة -->
    <footer class="footer">
      <p>نظام إدارة العيادات © 2026 | مدعوم بـ <a href="https://supabase.com" target="_blank">Supabase</a></p>
    </footer>
  </div>

  <script>
    // ⚙️ إعدادات Supabase (من المستخدم)
    const SUPABASE_URL = 'https://ncqvzpcqotdiwjqbwlwp.supabase.co';
    const SUPABASE_ANON_KEY = 'sb_publishable_98lfpU1zaqG-MNxkhlvg6g_KEMPMPbS';

    // تهيئة عميل Supabase [[16]][[18]]
    const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    // متغيرات التطبيق
    let html5QrcodeScanner = null;
    let isScanning = false;
    let lastScannedCode = null;

    // عناصر DOM
    const elements = {
      startBtn: document.getElementById('startScan'),
      stopBtn: document.getElementById('stopScan'),
      flipBtn: document.getElementById('flipCamera'),
      qrReader: document.getElementById('qr-reader'),
      resultCard: document.getElementById('resultCard'),
      resultIcon: document.getElementById('resultIcon'),
      resultTitle: document.getElementById('resultTitle'),
      qrContent: document.getElementById('qrContent'),
      appointmentDetails: document.getElementById('appointmentDetails'),
      loading: document.getElementById('loading'),
      statusMessage: document.getElementById('statusMessage')
    };

    // 🎯 دالة عرض رسالة الحالة
    function showStatus(message, type = 'info') {
      elements.statusMessage.textContent = message;
      elements.statusMessage.className = `status-message ${type} show`;
      
      // إخفاء الرسالة تلقائيًا بعد 5 ثوانٍ
      if (type !== 'error') {
        setTimeout(() => {
          elements.statusMessage.classList.remove('show');
        }, 5000);
      }
    }

    // 🎯 دالة البحث في قاعدة البيانات
    async function searchInDatabase(qrCode) {
      showStatus('جاري البحث...', 'info');
      elements.loading.classList.add('show');
      elements.resultCard.classList.remove('show');

      try {
        // البحث في جدول المواعيد حسب الـ ID أو أي حقل فريد
        // يمكنك تعديل هذا الاستعلام حسب هيكل بياناتك [[16]]
        const { data, error } = await supabase
          .from('appointments')
          .select('*')
          .or(`id.eq.${qrCode},phone.eq.${qrCode}`)
          .maybeSingle();

        if (error) throw error;

        if (data) {
          displayAppointmentResult(data, qrCode);
          showStatus('✅ تم العثور على الموعد!', 'success');
        } else {
          displayNotFoundResult(qrCode);
          showStatus('⚠️ لم يتم العثور على بيانات لهذا الكود', 'error');
        }
      } catch (err) {
        console.error('خطأ في البحث:', err);
        displayErrorResult(qrCode, err.message);
        showStatus('❌ حدث خطأ أثناء البحث', 'error');
      } finally {
        elements.loading.classList.remove('show');
      }
    }

    // 🎯 عرض نتيجة الموعد الناجحة
    function displayAppointmentResult(appointment, qrCode) {
      elements.resultIcon.className = 'result-icon success';
      elements.resultIcon.textContent = '✓';
      elements.resultTitle.textContent = '📋 تفاصيل الموعد';
      elements.qrContent.textContent = qrCode;

      // تنسيق التاريخ والوقت
      const appointmentDate = new Date(appointment.appointment_date);
      const formattedDate = appointmentDate.toLocaleDateString('ar-EG', {
        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
      });

      elements.appointmentDetails.innerHTML = `
        <div class="detail-row">
          <span class="detail-label">اسم المريض</span>
          <span class="detail-value">${appointment.patient_name}</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">رقم الهاتف</span>
          <span class="detail-value" dir="ltr">${appointment.phone}</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">تاريخ الموعد</span>
          <span class="detail-value">${formattedDate}</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">وقت الموعد</span>
          <span class="detail-value">${appointment.appointment_time}</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">الحالة</span>
          <span class="detail-value">
            <span class="status-badge status-${appointment.status}">
              ${getStatusText(appointment.status)}
            </span>
          </span>
        </div>
        <div class="detail-row">
          <span class="detail-label">تاريخ الإنشاء</span>
          <span class="detail-value">${new Date(appointment.created_at).toLocaleString('ar-EG')}</span>
        </div>
      `;

      elements.resultCard.classList.add('show');
    }

    // 🎯 عرض نتيجة "غير موجود"
    function displayNotFoundResult(qrCode) {
      elements.resultIcon.className = 'result-icon not-found';
      elements.resultIcon.textContent = '?';
      elements.resultTitle.textContent = '⚠️ غير موجود';
      elements.qrContent.textContent = qrCode;
      elements.appointmentDetails.innerHTML = `
        <div style="text-align: center; color: var(--text-secondary); padding: 10px;">
          لا توجد بيانات مطابقة لهذا الكود في قاعدة البيانات.
          <br><br>
          <small>تأكد من صحة الكود أو قم بإضافته أولاً</small>
        </div>
      `;
      elements.resultCard.classList.add('show');
    }

    // 🎯 عرض نتيجة الخطأ
    function displayErrorResult(qrCode, errorMessage) {
      elements.resultIcon.className = 'result-icon error';
      elements.resultIcon.textContent = '!';
      elements.resultTitle.textContent = '❌ خطأ';
      elements.qrContent.textContent = qrCode;
      elements.appointmentDetails.innerHTML = `
        <div style="text-align: center; color: var(--danger); padding: 10px;">
          ${errorMessage || 'حدث خطأ غير متوقع'}
        </div>
      `;
      elements.resultCard.classList.add('show');
    }

    // 🎯 ترجمة حالة الموعد
    function getStatusText(status) {
      const statuses = {
        'pending': 'قيد الانتظار',
        'confirmed': 'مؤكد',
        'cancelled': 'ملغي',
        'completed': 'مكتمل'
      };
      return statuses[status] || status;
    }

    // 🎯 دالة معالجة نتيجة المسح الناجحة [[2]][[3]]
    async function onScanSuccess(decodedText, decodedResult) {
      // تجاهل المسح المتكرر لنفس الكود
      if (decodedText === lastScannedCode) return;
      
      lastScannedCode = decodedText;
      console.log('📦 تم مسح الكود:', decodedText);

      // إيقاف المسح مؤقتًا أثناء المعالجة
      if (html5QrcodeScanner) {
        html5QrcodeScanner.pause();
      }

      // البحث في قاعدة البيانات
      await searchInDatabase(decodedText);

      // إعادة تفعيل المسح بعد ثانية واحدة
      setTimeout(() => {
        if (html5QrcodeScanner && isScanning) {
          html5QrcodeScanner.resume();
        }
        lastScannedCode = null; // السماح بمسح نفس الكود لاحقًا
      }, 1500);
    }

    // 🎯 دالة معالجة أخطاء المسح
    function onScanError(errorMessage) {
      // نتجاهل معظم الأخطاء لتجنب الإزعاج
      // يمكن تسجيل الأخطاء المهمة فقط
      // console.warn('مسح:', errorMessage);
    }

    // 🎯 بدء الماسح الضوئي
    function startScanner() {
      if (isScanning) return;

      // تهيئة الماسح مع إعدادات محسّنة [[2]][[7]]
      html5QrcodeScanner = new Html5QrcodeScanner(
        "qr-reader",
        {
          fps: 10,
          qrbox: { width: 250, height: 250 },
          rememberLastUsedCamera: true,
          supportedScanTypes: [Html5QrcodeScanType.SCAN_TYPE_CAMERA]
        },
        /* verbose= */ false
      );

      html5QrcodeScanner.render(onScanSuccess, onScanError)
        .then(() => {
          isScanning = true;
          elements.startBtn.disabled = true;
          elements.stopBtn.disabled = false;
          elements.startBtn.classList.remove('pulse');
          showStatus('🎥 الكاميرا نشطة - وجّه الكيو آر نحو العدسة', 'info');
        })
        .catch(err => {
          console.error('خطأ في بدء الماسح:', err);
          showStatus('❌ تعذر الوصول للكاميرا. تأكد من الأذونات', 'error');
        });
    }

    // 🎯 إيقاف الماسح الضوئي
    function stopScanner() {
      if (!isScanning || !html5QrcodeScanner) return;

      html5QrcodeScanner.clear()
        .then(() => {
          isScanning = false;
          elements.startBtn.disabled = false;
          elements.stopBtn.disabled = true;
          elements.startBtn.classList.add('pulse');
          showStatus('⏹ تم إيقاف المسح', 'info');
        })
        .catch(err => {
          console.error('خطأ في إيقاف الماسح:', err);
        });
    }

    // 🎯 تبديل الكاميرا (أمامية/خلفية)
    function flipCamera() {
      if (!isScanning || !html5QrcodeScanner) {
        showStatus('ابدأ المسح أولاً لتبديل الكاميرا', 'info');
        return;
      }
      
      // html5-qrcode تدعم تبديل الكاميرا تلقائيًا عند إعادة التشغيل
      stopScanner();
      setTimeout(() => {
        startScanner();
        showStatus('🔄 جاري تبديل الكاميرا...', 'info');
      }, 500);
    }

    // 🎯 إعداد أحداث الأزرار
    elements.startBtn.addEventListener('click', startScanner);
    elements.stopBtn.addEventListener('click', stopScanner);
    elements.flipBtn.addEventListener('click', flipCamera);

    // 🎯 بدء التطبيق
    document.addEventListener('DOMContentLoaded', () => {
      console.log('✅ التطبيق جاهز - قارئ الكيو آر مع Supabase');
      showStatus('👆 اضغط على "بدء المسح" للبدء', 'info');
      
      // التحقق من دعم الكاميرا
      if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
        showStatus('⚠️ متصفحك لا يدعم الوصول للكاميرا', 'error');
        elements.startBtn.disabled = true;
      }
    });

    // 🎯 تنظيف عند إغلاق الصفحة
    window.addEventListener('beforeunload', () => {
      if (html5QrcodeScanner && isScanning) {
        html5QrcodeScanner.clear().catch(() => {});
      }
    });
  </script>
</body>
</html>
